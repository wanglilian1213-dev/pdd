# Copy this file to .env.e2e and fill in real values.
# .env.e2e is gitignored — never commit it.
#
# Usage:
#   set -a && source .env.e2e && set +a && node test-revision-full-e2e.mjs

SUPABASE_URL=https://your-project.supabase.co
# E2E 脚本专用变量，值和 SUPABASE_SERVICE_ROLE_KEY 相同。
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
E2E_API_URL=https://your-app.up.railway.app
