{
  "name": "pindaidai-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:cleanup": "node dist/cleanup.js",
    "repair:delivery": "tsx src/scripts/repairDeliveryFiles.ts",
    "repair:completed": "tsx src/scripts/remediateCompletedTasks.ts",
    "repair:wallets": "tsx src/scripts/repairMissingWallets.ts",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@sentry/node": "^10.46.0",
    "@supabase/supabase-js": "^2.49.0",
    "cors": "^2.8.5",
    "docx": "^9.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "openai": "^4.80.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.3",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
