# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
# 可选：自定义 API 代理地址（不填则走 OpenAI 官方）
OPENAI_BASE_URL=
# Required. Current main writing chain only supports gpt-5.5 here.
OPENAI_MODEL=gpt-5.5

# StealthWriter（降 AI + AI 检测）
# 默认官方站点；只有做自建反向代理时才需要覆盖
STEALTHWRITER_BASE_URL=https://stealthwriter.ai
# 可选：常驻登录 worker 的私有地址（cleanup / app 需要时会调用它刷新会话）
STEALTHWRITER_WORKER_URL=
# 可选：worker 私有鉴权 token（配了 worker 就一起配）
STEALTHWRITER_WORKER_TOKEN=

# 允许跨域访问后端的前端域名（逗号分隔）
ALLOWED_ORIGINS=https://pindaidai.uk,https://www.pindaidai.uk,https://pindaidai.up.railway.app,http://localhost:3000,http://localhost:4173

# 运营白名单（逗号分隔）
OPS_WHITELIST_EMAILS=admin@example.com

# 配置缓存（毫秒）
CONFIG_CACHE_TTL_MS=60000

# 可选：错误监控（不填就只打日志，不会阻止服务启动）
SENTRY_DSN=

# 服务配置
PORT=3001
NODE_ENV=development
