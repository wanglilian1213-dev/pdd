# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
# Required. Current main writing chain only supports gpt-5.4 here.
OPENAI_MODEL=gpt-5.4

# Undetectable Humanization API（降 AI）
UNDETECTABLE_API_KEY=
# 降 AI 当前固定使用：model=v11sr, strength=More Human, readability=University, purpose=Essay

# 运营白名单（逗号分隔）
OPS_WHITELIST_EMAILS=admin@example.com

# 服务配置
PORT=3001
NODE_ENV=development
